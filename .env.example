# =====================================================================
#  MẪU BIẾN MÔI TRƯỜNG (được commit vào repo làm tài liệu tham chiếu).
#  KHÔNG điền secret thật vào file này.
#
#  Cách dùng:
#   - Chạy local:  copy file này thành .env.local rồi điền (hoặc để trống = mock)
#                  cp .env.example .env.local
#   - Deploy thật: khai báo các biến dưới đây trong môi trường của nền tảng
#                  (Vercel/Docker/VPS...), KHÔNG commit giá trị thật.
# =====================================================================

# ---- MISA AMIS Kế toán (Open API) ----------------------------------
# Nguồn master data (NCC / hàng hóa / ĐVT / kho / phòng ban).
# Có ĐỦ 3 biến sau  -> chế độ LIVE (gọi MISA thật).
# Thiếu bất kỳ biến -> chế độ MOCK (dùng dữ liệu giả trong src/lib/misa/fixtures.ts).
#
#   app_id            : xin từ NVKD MISA khi đăng ký dùng Open API
#   access_code       : lấy trong AMIS Kế toán (tài khoản có quyền Admin dữ liệu)
#   org_company_code  : mã đơn vị/dữ liệu, xác nhận cùng NVKD MISA
MISA_APP_ID=your-misa-app-id
MISA_ACCESS_CODE=your-misa-access-code
MISA_ORG_COMPANY_CODE=your-org-company-code

# URL API MISA (mặc định nếu bỏ trống: https://actapp.misa.vn)
MISA_BASE_URL=https://actapp.misa.vn

# Tự đồng bộ MISA khi khởi động server (true/false). Mặc định true.
# false = chỉ đồng bộ thủ công qua nút trong Cấu hình.
MISA_AUTO_SYNC=true

# ---- CƠ SỞ DỮ LIỆU -------------------------------------------------
# CÓ DATABASE_URL  -> app nối thẳng PostgreSQL thật (Supabase).
# KHÔNG có          -> dùng PGlite nhúng (DB local ./.pglite), như mặc định.
#
# Lấy chuỗi ở: Supabase Dashboard -> Project Settings -> Database ->
# Connection string. KHUYÊN dùng "Connection pooling" (Supavisor, cổng 6543)
# cho app serverless/Next.js; thay [PASSWORD] bằng mật khẩu DB thật.
#   Pooler : postgresql://postgres.kenrqbkgammyivutnnfm:[PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres
#   Direct : postgresql://postgres:[PASSWORD]@db.kenrqbkgammyivutnnfm.supabase.co:5432/postgres
# DATABASE_URL=

# Nạp DỮ LIỆU MẪU (công ty/tài khoản/hàng hóa demo) khi khởi động.
# Chỉ có tác dụng ở chế độ Postgres. true = nạp demo để thử; để trống/false
# = KHÔNG nạp (dùng khi đã có tài khoản & dữ liệu thật trên Supabase).
# DB_SEED=false

# Số kết nối tối đa trong pool (mặc định 5). Tùy chọn.
# DB_POOL_MAX=5
